# Required: get one at https://console.anthropic.com/
ANTHROPIC_API_KEY=sk-ant-...

# Optional: enables LangSmith tracing
# LANGSMITH_API_KEY=ls__...
# LANGSMITH_PROJECT=co-scientist

# Optional: if/when you point at a self-hosted BioNeMo NIM
# BIONEMO_BASE_URL=http://localhost:8000
# BIONEMO_API_KEY=...

# Optional: NCBI E-utilities is faster with an email + key
# NCBI_EMAIL=you@example.com
# NCBI_API_KEY=

# Optional: enables one-click Colab handoff when no `gh` CLI is installed
# (e.g. on Streamlit Cloud). Create a fine-grained PAT at
# https://github.com/settings/tokens?type=beta with `gist:write` scope only.
# GITHUB_TOKEN=ghp_...
